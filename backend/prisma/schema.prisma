generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  email    String    @unique
  password String
  role     Role      @default(USER)
  witze    Witz[]
  likes    Like[]
  comments Comment[]
  notifications Notification[]
}

model Kategorie {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  emoji     String
  createdAt DateTime @default(now())
  witze     Witz[]
}

model Witz {
  id          Int        @id @default(autoincrement())
  text        String
  authorId    Int?
  kategorieId Int?
  likes       Int        @default(0) // ← COUNTER (Zahl)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  author      User?      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kategorie   Kategorie? @relation(fields: [kategorieId], references: [id])
  likeLikes   Like[] // ← RELATION (Array) — NEUER NAME!
  comments    Comment[]
  isEdited  Boolean  @default(false)

  @@index([authorId])
  @@index([kategorieId])
  @@map("witz")
}

model Like {
  id     Int  @id @default(autoincrement())
  userId Int
  witzId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  witz   Witz @relation(fields: [witzId], references: [id], onDelete: Cascade)

  @@unique([userId, witzId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  authorId  Int
  witzId    Int
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  witz      Witz     @relation(fields: [witzId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  value       String
  description String?
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'like' | 'comment'
  message   String
  witzId    Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}


enum Role {
  USER
  ADMIN
  BETA
  MODERATOR
}
