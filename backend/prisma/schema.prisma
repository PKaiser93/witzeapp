generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  username String    @unique
  email    String    @unique
  password String
  role     Role      @default(USER)
  isVerified       Boolean  @default(false)
  witze    Witz[]
  likes    Like[]
  comments Comment[]
  notifications Notification[]
  reports Report[]
  auditLogs AuditLog[]
  bio String? @default("")

  ban            Ban?
  warnings       Warning[]
  bansGiven      Ban[]     @relation("BannedBy")
  warningsGiven  Warning[] @relation("WarnedBy")
  following    Follow[] @relation("Follower")
  followers    Follow[] @relation("Following")
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastPostDate   DateTime?
  badges Badge[]
  verificationTokens VerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  refreshTokens RefreshToken[]
  createdAt     DateTime  @default(now())
  updatedAt        DateTime @updatedAt
  isBlueVerified  Boolean  @default(false)
  verifiedApplication     VerifiedApplication?
  reviewedApplications    VerifiedApplication[] @relation("ReviewedBy")
}

model VerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}


model Badge {
  id          Int       @id @default(autoincrement())
  userId      Int
  key         String
  awardedAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}


model Kategorie {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  emoji     String
  createdAt DateTime @default(now())
  witze     Witz[]
}

model Witz {
  id          Int        @id @default(autoincrement())
  text        String
  authorId    Int?
  kategorieId Int?
  likes       Int        @default(0) // ← COUNTER (Zahl)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  author      User?      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kategorie   Kategorie? @relation(fields: [kategorieId], references: [id])
  likeLikes   Like[] // ← RELATION (Array) — NEUER NAME!
  comments    Comment[]
  isEdited  Boolean  @default(false)
  reports Report[]

  @@index([authorId])
  @@index([kategorieId])
  @@map("witz")
}

model Like {
  id     Int  @id @default(autoincrement())
  userId Int
  witzId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  witz   Witz @relation(fields: [witzId], references: [id], onDelete: Cascade)

  @@unique([userId, witzId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  authorId  Int
  witzId    Int
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  witz      Witz     @relation(fields: [witzId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  value       String
  description String?
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'like' | 'comment'
  message   String
  witzId    Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id        Int      @id @default(autoincrement())
  witzId    Int
  userId    Int
  reason    String
  createdAt DateTime @default(now())
  resolved  Boolean  @default(false)
  witz      Witz     @relation(fields: [witzId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, witzId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  adminId   Int
  details   String?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Ban {
  id        Int       @id @default(autoincrement())
  userId    Int       @unique
  reason    String
  bannedBy  Int
  bannedAt  DateTime  @default(now())
  expiresAt DateTime?  // null = permanent
  active    Boolean   @default(true)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin     User      @relation("BannedBy", fields: [bannedBy], references: [id])
}

model Warning {
  id        Int      @id @default(autoincrement())
  userId    Int
  reason    String
  warnedBy  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin     User     @relation("WarnedBy", fields: [warnedBy], references: [id])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlacklistedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model VerifiedApplication {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique  // Nur eine aktive Bewerbung pro User
  status      ApplicationStatus @default(PENDING)
  message     String?           // Optionaler Bewerbungstext vom User
  adminNote   String?           // Notiz vom Admin bei Ablehnung
  reviewedBy  Int?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin       User?     @relation("ReviewedBy", fields: [reviewedBy], references: [id])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}


enum Role {
  USER
  ADMIN
  BETA
  MODERATOR
}
